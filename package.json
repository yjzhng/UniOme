{
  "name": "uniome",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "trap 'kill 0' EXIT; npm run dev:api & npm run dev:web",
    "dev:api": "npm run dev -w @uniome/api",
    "dev:web": "npm run dev -w @uniome/web",
    "dev:desktop": "npm run dev -w @uniome/desktop",
    "build": "npm run build -w @uniome/web",
    "dist": "npm run dist -w @uniome/desktop",
    "dist:arm64": "npm run dist:arm64 -w @uniome/desktop",
    "dist:x64": "npm run dist:x64 -w @uniome/desktop",
    "setup": "node scripts/unpack-assets.mjs",
    "fetch-assets": "node scripts/general/fetch-protein-assets.mjs 83333",
    "pack-assets": "node scripts/pack-assets.mjs",
    "build-organism": "node scripts/build-organism.mjs"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "npm-run-all": "^4.1.5",
    "playwright-core": "^1.61.1",
    "typescript": "^5.6.0",
    "xlsx": "^0.18.5"
  }
}
