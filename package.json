{
  "name": "uniome",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run dev -w @uniome/api",
    "dev:web": "npm run dev -w @uniome/web",
    "build": "npm run build -w @uniome/web",
    "setup": "node scripts/unpack-assets.mjs",
    "fetch-assets": "node scripts/fetch-protein-assets.mjs 83333",
    "pack-assets": "node scripts/pack-assets.mjs"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.0"
  }
}
